{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "User API v1",
  "type": "object",
  "properties": {
    "id": { "type": "integer" },
    "name": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "avatar_url": { "type": "string", "format": "uri" },
    "role": { "type": "string", "enum": ["admin", "user", "viewer"] },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": ["id", "name", "email"]
}
