{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Format Schema",
  "type": "object",
  "properties": {
    "email": { "type": "string", "format": "email" },
    "homepage": { "type": "string", "format": "uri" },
    "created": { "type": "string", "format": "date-time" },
    "nested": {
      "type": "object",
      "properties": {
        "ip": { "type": "string", "format": "ipv4" }
      }
    }
  },
  "required": ["email"]
}
