{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "cli/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "cli/__tests__/**",
    "**/*.test.ts",
    "node_modules",
    "dist"
  ]
}
